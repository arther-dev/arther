# Arther environment — copy to .env (gitignored) and fill in.
# Tags: [local] usable now · [P1-cloud] needed at F0.2–F0.4 · [P2+] needed at Phase 2 G1+
# All values are SERVER-SIDE ONLY. Nothing here may reach a client bundle.

# [local] Dockerized Postgres for migrations + DB tests (scripts/db-up.sh)
DATABASE_URL=postgres://postgres:postgres@localhost:54329/arther

# [P1-cloud] Supabase (F0.2)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# [P1-cloud] Public app origin for Supabase auth redirects (F2.1/F2.3).
# Local default http://localhost:3000; Vercel: https://arther-app.vercel.app
APP_URL=

# [P1-cloud] Sentry (F0.4) — DSNs are public ingest keys, not secrets.
# Server + edge runtime:
SENTRY_DSN=
# Client bundle (same DSN value, NEXT_PUBLIC_ so Next inlines it):
NEXT_PUBLIC_SENTRY_DSN=
# Source-map upload (CI/Vercel only; THESE are secrets):
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# [M3+] Anthropic — single ai-gateway call site (ADR-007); first used by F7.2 import, full at G1
ANTHROPIC_API_KEY=

# [P2+] Trigger.dev durable jobs (ADR-006, G1.2)
TRIGGER_SECRET_KEY=

# [P3] Resend transactional email (ADR-011, C3.3 / F4.3)
RESEND_API_KEY=

# [P1-cloud F8.2 / P2 G8.5] Upstash Redis rate limiting (ADR-014)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
