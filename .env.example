# Arther environment — copy to .env (gitignored) and fill in.
# Tags: [local] usable now · [P1-cloud] needed at F0.2–F0.4 · [P2+] needed at Phase 2 G1+
# All values are SERVER-SIDE ONLY. Nothing here may reach a client bundle.

# [local] Dockerized Postgres for migrations + DB tests (scripts/db-up.sh)
DATABASE_URL=postgres://postgres:postgres@localhost:54329/arther

# [P1-cloud] Supabase (F0.2)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# [P1-cloud] Public app origin for Supabase auth redirects (F2.1/F2.3).
# Local default http://localhost:3000; Vercel: https://arther-app.vercel.app
APP_URL=

# [P1-cloud] Sentry (F0.4) — DSNs are public ingest keys, not secrets.
# Server + edge runtime:
SENTRY_DSN=
# Client bundle (same DSN value, NEXT_PUBLIC_ so Next inlines it):
NEXT_PUBLIC_SENTRY_DSN=
# Source-map upload (CI/Vercel only; THESE are secrets):
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# [M3+] Anthropic — single ai-gateway call site (ADR-007); first used by F7.2 import, full at G1
ANTHROPIC_API_KEY=

# [P2+] Trigger.dev durable jobs (ADR-006, G1.2)
TRIGGER_SECRET_KEY=

# [P3] Resend transactional email (ADR-011, C3.3 / F4.3)
RESEND_API_KEY=
# Sender for app invitations (F4.3). Must be on a domain verified in
# Resend to reach arbitrary recipients, e.g. "Arther <invites@arther.io>".
# Unset → Resend's onboarding@resend.dev (delivers only to the account owner).
RESEND_FROM=

# [P1-cloud F8.2 / P2 G8.5] Upstash Redis rate limiting (ADR-014)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# [P3 C6.5] Publishing portal — on-publish cache revalidation (app → portal webhook).
# The portal's /api/revalidate endpoint URL and the shared bearer secret. Unset →
# the portal's ISR interval is the only refresh path (no on-publish busting).
PORTAL_REVALIDATE_URL=
PORTAL_REVALIDATE_SECRET=

# [P3 C7] Gated access (magic links). PORTAL_BASE_URL is the portal's public origin
# (used by the app to build access links, e.g. https://arther-portal.vercel.app).
# PORTAL_SESSION_SECRET signs the 24-hour portal access-session cookie + hashes
# access-log IPs (a strong random secret; set on BOTH app and portal). Unset →
# gated access is disabled (links can't be issued; the gate stays closed).
PORTAL_BASE_URL=
PORTAL_SESSION_SECRET=
