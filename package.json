{
  "name": "arther",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "dev": "turbo run dev",
    "db:up": "bash scripts/db-up.sh",
    "db:down": "bash scripts/db-down.sh",
    "db:migrate": "bash scripts/db-migrate.sh",
    "db:seed": "bash scripts/db-seed.sh",
    "db:reset": "bash scripts/db-down.sh && bash scripts/db-up.sh && bash scripts/db-migrate.sh && bash scripts/db-seed.sh",
    "test:db": "pnpm --filter @arther/db-tests test:db",
    "test:e2e": "pnpm --filter @arther/e2e test:e2e",
    "test:screens": "pnpm --filter @arther/e2e test:screens",
    "check:drift": "bash scripts/check-migration-drift.sh",
    "check:guardrails": "bash scripts/check-protected-paths.sh"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.8.0",
    "eslint": "^9.27.0",
    "typescript-eslint": "^8.32.0",
    "@eslint/js": "^9.27.0",
    "prettier": "^3.5.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@sentry/cli",
      "esbuild",
      "sharp",
      "@tailwindcss/oxide",
      "unrs-resolver"
    ]
  }
}
