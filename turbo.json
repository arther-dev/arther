{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "app#typecheck": {
      "dependsOn": ["app#build"]
    },
    "portal#typecheck": {
      "dependsOn": ["portal#build"]
    },
    "test": {},
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
